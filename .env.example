# Copy this file to .env and fill in real values. Never commit .env.
# Public deployments must inject these via platform secrets, not files.

# App mode: demo | live | auto
#   demo  → always use bundled sample data (no network calls)
#   live  → require live providers, surface failures honestly
#   auto  → live if NEWSAPI_KEY is set, otherwise demo
APP_MODE=auto

# NewsAPI (https://newsapi.org). Free tier: ~100 req/day, dev-only.
# Leave blank to run in demo mode.
NEWSAPI_KEY=

# Optional paid maritime providers (placeholders — not yet integrated).
BALTIC_EXCHANGE_KEY=
CLARKSONS_KEY=
VESSELSVALUE_KEY=
KPLER_KEY=
MARINETRAFFIC_KEY=
